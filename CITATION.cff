# YAML file in Citation File Format 1.2.0 (https://citation-file-format.github.io/).
# Used by GitHub, Zenodo, and citation tools to generate accurate citations.

cff-version: 1.2.0
message: >-
  If you use this software, please cite both the software (this CITATION
  file) and the accompanying paper (see preferred-citation below).
type: software
title: "GPU-Accelerated FTLM for Heisenberg Spin Clusters"
abstract: >-
  Matrix-free GPU implementation of the Finite-Temperature Lanczos Method
  for Heisenberg spin clusters with uniform nearest-neighbor exchange
  coupling, with sector decomposition by total S^z and a block-Lanczos
  sweep over random vectors. Computes the specific heat C(T), magnetic
  susceptibility chi(T), and the effective partition function Z_eff(T)
  on a user-supplied temperature grid. The production path runs in
  single precision on the GPU (CUDA); a double-precision OpenMP
  CPU path is available as a reference.
version: "1.1.0"
date-released: "2026-07-03"
license: Apache-2.0
repository-code: "https://github.com/ghasdeke/ftlm-gpu"
doi: "10.5281/zenodo.20378647"   # Zenodo archive of the software (see paper)
keywords:
  - Heisenberg model
  - spin cluster
  - exact diagonalization
  - Finite-Temperature Lanczos Method
  - block Lanczos
  - matrix-free
  - GPU
  - CUDA
  - OpenMP
  - finite-temperature thermodynamics

authors:
  - family-names: "Ghassemi Tabrizi"
    given-names: "Shadan"
    affiliation: >-
      Technische Universitaet Dresden, and
      Helmholtz-Zentrum Dresden-Rossendorf
    # orcid: "https://orcid.org/XXXX-XXXX-XXXX-XXXX"   # optional, fill in or remove

# Preferred citation: the accompanying paper.
# Fill in journal, doi, volume, pages once accepted/published.
